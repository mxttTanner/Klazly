NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Email of the platform owner. Whoever logs in with this email gets access to
# /super-admin, where they can create new center accounts. Comma-separated for
# multiple owners.
SUPER_ADMIN_EMAIL=

# --- Optional: production-only services -------------------------------------
# Resend (transactional email — new-message notifications to parents/teachers).
# Without RESEND_API_KEY, email sends are silently skipped (logged once).
# RESEND_FROM_EMAIL should point at a verified domain in production; falls back
# to Resend's shared sender "onboarding@resend.dev" for testing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Used in email links so they point at the right host.
NEXT_PUBLIC_APP_URL=

# Server timezone. The runtime defaults to UTC on Vercel; setting this so
# that toLocaleDateString() / toLocaleString() server-side render dates in
# Vietnam time. Without this, a trial_ends_at of 23:00 UTC shows the wrong
# day for VN users near midnight.
# Set this in Vercel project settings → Environment Variables for prod.
TZ=Asia/Ho_Chi_Minh

# Sentry (error monitoring). DSN keys are split into client + server so each
# runtime can be initialised independently. Without DSN, the SDK no-ops.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only needed if you want source maps uploaded at build time. Skip for now.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
